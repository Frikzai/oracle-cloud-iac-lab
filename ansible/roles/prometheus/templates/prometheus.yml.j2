global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets:
          - "127.0.0.1:9090"

  - job_name: "node_exporter"
    static_configs:
      - targets:
          - "127.0.0.1:9100"
        labels:
          instance: "oci-bastion"
          role: "bastion"

      - targets:
          - "{{ app_private_ip }}:9100"
        labels:
          instance: "oci-app-1"
          role: "app"
